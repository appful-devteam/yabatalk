    "来月のアクション" : {
      "comment" : "Title of a section that lists upcoming actions.",
      "extractionState" : "stale",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Next Month's Actions"
          }
