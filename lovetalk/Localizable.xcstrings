    "トーク量" : {
      "comment" : "A label for the color-coded legend item.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Chat Volume"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Volumen de Chat"
          }
        },
        "ko" : {
          "stringUnit" : {
