    "気まぐれでマイペース。ツンデレ気質の猫のような性格です。" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Whimsical and self-paced. A cat-like personality with tsundere tendencies."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Caprichoso y a su ritmo. Una personalidad gatuna con tendencias tsundere."
