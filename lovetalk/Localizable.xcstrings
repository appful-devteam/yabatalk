    "マメでポジティブ、ロマンチスト。まっすぐな愛情表現が魅力の一途タイプです。" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attentive, positive, and romantic. A devoted type whose charm is in their straightforward love."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Atento, positivo y romántico. Un tipo devoto cuyo encanto está en su amor directo."
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "섬세하고 긍정적이며 로맨틱한 한결같은 타입. 솔직한 애정 표현이 매력입니다."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "细心、积极又浪漫。以直率的爱情表达为魅力的专一类型。"
          }
        }
      }
    },
    "マメ度" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
